{
  "_comment": [
    "EXAMPLE: LLM Router with 3 llama.cpp sub-containers.",
    "- embed: BGE-M3 embedding model (always running, shared by openmemory)",
    "- qwen: Qwen 3.5 for chat/reasoning (on-demand)",
    "- glm4: GLM-4 Flash for fast inference (on-demand)",
    "",
    "Copy this to config/service.json to use."
  ],

  "name": "llm-router",
  "version": "0.1.0",
  "description": "LLM inference router with on-demand llama.cpp sub-containers",

  "mcp_enabled": true,
  "mcp_path_prefix": "/mcp",

  "containers": {
    "defaults": {
      "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
      "internal_port": 8080,
      "idle_timeout_seconds": 300,
      "startup_timeout_seconds": 120,
      "health_check": {
        "endpoint": "/health",
        "interval_seconds": 10,
        "timeout_seconds": 5,
        "retries": 3
      },
      "resources": {
        "cpu_limit": "4",
        "memory_limit": "8g"
      }
    },

    "definitions": {
      "embed": {
        "command": [
          "--model", "/models/bge-m3-Q8_0.gguf",
          "--port", "8080",
          "--embedding",
          "--gpu-layers", "99",
          "--ctx-size", "8192"
        ],
        "volumes": {
          "llm-models": "/models"
        },
        "gpu": {
          "device_ids": ["0"],
          "memory_fraction": 0.2,
          "exclusive": false
        },
        "idle_timeout_seconds": 0,
        "auto_start": true,
        "group": "inference",
        "labels": {
          "model.type": "embedding",
          "model.name": "bge-m3"
        }
      },

      "qwen": {
        "command": [
          "--model", "/models/qwen3.5-7b-Q4_K_M.gguf",
          "--port", "8080",
          "--gpu-layers", "99",
          "--ctx-size", "32768",
          "--parallel", "2"
        ],
        "volumes": {
          "llm-models": "/models"
        },
        "gpu": {
          "device_ids": ["0"],
          "memory_fraction": 0.6,
          "exclusive": false
        },
        "idle_timeout_seconds": 300,
        "group": "inference",
        "labels": {
          "model.type": "chat",
          "model.name": "qwen3.5-7b"
        }
      },

      "glm4": {
        "command": [
          "--model", "/models/glm-4-9b-chat-Q4_K_M.gguf",
          "--port", "8080",
          "--gpu-layers", "99",
          "--ctx-size", "16384",
          "--flash-attn"
        ],
        "volumes": {
          "llm-models": "/models"
        },
        "gpu": {
          "device_ids": ["0"],
          "memory_fraction": 0.5,
          "exclusive": false
        },
        "idle_timeout_seconds": 180,
        "group": "inference",
        "labels": {
          "model.type": "chat",
          "model.name": "glm-4-9b-flash"
        }
      }
    }
  },

  "custom": {
    "compose_project_name": "llm-router",
    "network_name": "llm-router-network"
  }
}
