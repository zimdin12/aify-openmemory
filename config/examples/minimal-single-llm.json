{
  "_comment": "EXAMPLE: Simplest possible config - one llama.cpp container.",
  "name": "my-llm",
  "version": "0.1.0",
  "description": "Single LLM service",
  "mcp_enabled": true,

  "containers": {
    "defaults": {
      "image": "ghcr.io/ggerganov/llama.cpp:server-cuda",
      "internal_port": 8080,
      "volumes": { "llm-models": "/models" },
      "gpu": { "device_ids": ["0"] },
      "idle_timeout_seconds": 300
    },
    "definitions": {
      "llm": {
        "command": ["--model", "/models/your-model.gguf", "--port", "8080", "--gpu-layers", "99"]
      }
    }
  }
}
