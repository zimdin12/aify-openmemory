# =============================================================================
# Aify OpenMemory - Configuration
# =============================================================================

# Service Identity
SERVICE_NAME=openmemory
SERVICE_VERSION=2.0.0
SERVICE_DESCRIPTION=Hybrid memory system with container orchestration

# Network
SERVICE_PORT=8765

# Docker
COMPOSE_PROJECT_NAME=aify-openmemory
DATA_VOLUME_NAME=openmemory-data
RESTART_POLICY=unless-stopped

# MCP
MCP_ENABLED=true
MCP_PATH_PREFIX=/mcp
MCP_USER_ID=steven
MCP_APP_NAME=claude-code

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Resource Limits (orchestrator)
CPU_LIMIT=2
MEMORY_LIMIT=4g

# Security
API_KEY=
CORS_ORIGINS=*

# =============================================================================
# LLM Backend (pluggable)
# =============================================================================
# Mode: external (URL to running service) | container (managed sub-container) | openai (cloud API)
LLM_MODE=external
# For external mode: URL to OpenAI-compatible API (Ollama, vLLM, llama.cpp, etc.)
LLM_API_URL=http://host.docker.internal:11434
# For container mode: name of container in service.json
# LLM_CONTAINER_NAME=inference-llm
# Provider hint: openai (default, for OpenAI-compatible APIs) | ollama (native Ollama API)
LLM_PROVIDER=openai
LLM_MODEL=qwen3.5:4b

# =============================================================================
# Embedder Backend (pluggable, same pattern as LLM)
# =============================================================================
EMBEDDER_MODE=external
EMBEDDER_API_URL=http://host.docker.internal:11434
# EMBEDDER_CONTAINER_NAME=inference-embed
EMBEDDER_PROVIDER=openai
EMBEDDER_MODEL=qwen3-embedding:0.6b

# =============================================================================
# Vector Store (Qdrant - managed as sub-container)
# =============================================================================
VECTOR_STORE_PROVIDER=qdrant
QDRANT_COLLECTION=openmemory
QDRANT_PORT=6333
QDRANT_EMBEDDING_DIMS=1024

# =============================================================================
# Graph Store (Neo4j - managed as sub-container)
# =============================================================================
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=openmemory

# =============================================================================
# Memory System
# =============================================================================
# User identity
USER=steven
# Memory features
MEMORY_MODE=advanced
LLM_FACT_REVIEW=true
SESSION_CONTEXT=true
BRAIN_MAX_STEPS=12

# Sub-services
SUB_SERVICES=
