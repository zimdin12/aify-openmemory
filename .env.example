# =============================================================================
# Agentify Container - Unified Configuration
# =============================================================================
# Copy to .env and customize. All values are overrideable.
# Service-specific settings go in config/service.json (copied from service.example.json)

# -----------------------------------------------------------------------------
# Service Identity
# -----------------------------------------------------------------------------
SERVICE_NAME=my-service
SERVICE_VERSION=0.1.0
SERVICE_DESCRIPTION=AI agent-accessible service

# -----------------------------------------------------------------------------
# Network / Ports
# -----------------------------------------------------------------------------
# Main API port (FastAPI + MCP SSE + container router)
SERVICE_PORT=8800

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=agentify-my-service
# Named volume for persistent data (fs-native speed)
DATA_VOLUME_NAME=service-data
# Restart policy: no | always | unless-stopped | on-failure
RESTART_POLICY=unless-stopped

# -----------------------------------------------------------------------------
# MCP Server
# -----------------------------------------------------------------------------
MCP_ENABLED=true
# SSE endpoint path prefix
MCP_PATH_PREFIX=/mcp
# Default user identity for MCP clients
MCP_USER_ID=default
# Default app/client name
MCP_APP_NAME=claude-code

# -----------------------------------------------------------------------------
# Sub-services (comma-separated list of service dirs under ./services/)
# Example: SUB_SERVICES=openmemory,llama-cpp
# Each sub-service must have its own docker-compose.yml
# -----------------------------------------------------------------------------
SUB_SERVICES=

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_FORMAT=json

# -----------------------------------------------------------------------------
# Resource Limits (for the orchestrator container itself)
# -----------------------------------------------------------------------------
CPU_LIMIT=2
MEMORY_LIMIT=4g

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# API key for protecting endpoints (empty = no auth)
API_KEY=
# CORS origins (comma-separated, * for all)
CORS_ORIGINS=*

# -----------------------------------------------------------------------------
# External Service URLs (for when this service depends on others)
# Override these when composing with other services
# -----------------------------------------------------------------------------
# OLLAMA_URL=http://ollama:11434
# QDRANT_URL=http://qdrant:6333
# NEO4J_URI=bolt://neo4j:7687
# OPENMEMORY_URL=http://openmemory-mcp:8765

# -----------------------------------------------------------------------------
# Custom Environment Variables
# Add service-specific variables below this line
# -----------------------------------------------------------------------------
